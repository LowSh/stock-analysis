#!/bin/bash

# Pre-commit hook: 自动检测和处理敏感信息
# 作者：OpenClaw Stock Analysis Skill
# 版本：1.0.0

echo "🔍 正在检查敏感信息..."

# 定义敏感信息模式
PATTERNS=(
    "+86 [0-9]{11}"           # 中国手机号
    "[0-9]{9}@qq\\.com"        # QQ邮箱
    "[a-z]{16}"                # 16位授权码（可能需要更精确的匹配）
)

# 定义替换文本
REPLACEMENTS=(
    "+86 YOUR_PHONE_NUMBER"
    "YOUR_EMAIL@qq.com"
    "YOUR_SMTP_AUTH_CODE"
)

# 定义要检查的文件
FILES_TO_CHECK=(
    "config.json"
    "CONFIG.md"
    "SKILL.md"
    "*.json"
    "*.md"
)

# 临时文件用于存储检测结果
TEMP_FILE="/tmp/sensitive_info_check.txt"
echo "" > "$TEMP_FILE"

# 检查是否有敏感信息
FOUND_SENSITIVE=false

# 获取所有待提交的文件
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM)

if [ -z "$STAGED_FILES" ]; then
    echo "✅ 没有待提交的文件"
    exit 0
fi

# 检查每个文件
for FILE in $STAGED_FILES; do
    # 跳过SECURITY.md（文档文件，包含示例）
    if [[ "$FILE" == "SECURITY.md" ]]; then
        continue
    fi

    # 只检查文本文件
    if [[ "$FILE" == *.json ]] || [[ "$FILE" == *.md ]] || [[ "$FILE" == *.txt ]]; then
        if [ -f "$FILE" ]; then
            # 检查手机号
            if grep -E "\+86 [0-9]{11}" "$FILE" > /dev/null 2>&1; then
                echo "⚠️  发现手机号：$FILE" >> "$TEMP_FILE"
                grep -n "\+86 [0-9]{11}" "$FILE" >> "$TEMP_FILE"
                FOUND_SENSITIVE=true
            fi

            # 检查QQ邮箱
            if grep -E "[0-9]{9}@qq\\.com" "$FILE" > /dev/null 2>&1; then
                echo "⚠️  发现QQ邮箱：$FILE" >> "$TEMP_FILE"
                grep -n "[0-9]{9}@qq\\.com" "$FILE" >> "$TEMP_FILE"
                FOUND_SENSITIVE=true
            fi

            # 检查16位授权码（更精确的匹配）
            if grep -E "(authCode|smtp).*[a-z]{16}" "$FILE" > /dev/null 2>&1; then
                echo "⚠️  发现可能的授权码：$FILE" >> "$TEMP_FILE"
                grep -n "(authCode|smtp).*[a-z]{16}" "$FILE" >> "$TEMP_FILE"
                FOUND_SENSITIVE=true
            fi
        fi
    fi
done

# 如果发现敏感信息
if [ "$FOUND_SENSITIVE" = true ]; then
    echo ""
    echo "🚨 警告：发现敏感信息！"
    echo "================================"
    cat "$TEMP_FILE"
    echo "================================"
    echo ""
    echo "请选择处理方式："
    echo "1) 自动替换敏感信息（推荐）"
    echo "2) 继续提交（不推荐，会泄露隐私）"
    echo "3) 取消提交"
    echo ""
    read -p "请输入选项 [1-3]: " choice

    case $choice in
        1)
            echo ""
            echo "🔧 正在自动替换敏感信息..."

            # 对每个文件进行替换
            for FILE in $STAGED_FILES; do
                if [[ "$FILE" == *.json ]] || [[ "$FILE" == *.md ]] || [[ "$FILE" == *.txt ]]; then
                    if [ -f "$FILE" ]; then
                        # 创建备份
                        cp "$FILE" "$FILE.bak"

                        # 替换手机号
                        sed -i '' 's/+86 [0-9]\{11\}/+86 YOUR_PHONE_NUMBER/g' "$FILE"

                        # 替换QQ邮箱
                        sed -i '' 's/[0-9]\{9\}@qq\.com/YOUR_EMAIL@qq.com/g' "$FILE"

                        # 替换授权码
                        sed -i '' 's/"authCode": "[^"]\{16\}"/"authCode": "YOUR_SMTP_AUTH_CODE"/g' "$FILE"

                        echo "✅ 已处理：$FILE"

                        # 重新添加到暂存区
                        git add "$FILE"
                    fi
                fi
            done

            echo ""
            echo "✅ 敏感信息已替换为占位符"
            echo "📝 提交将继续进行..."
            ;;

        2)
            echo ""
            echo "⚠️  警告：你选择继续提交敏感信息！"
            echo "⚠️  这可能会泄露你的隐私！"
            echo ""
            read -p "确定要继续吗？[y/N]: " confirm
            if [[ "$confirm" =~ ^[Yy]$ ]]; then
                echo "⚠️  继续提交..."
            else
                echo "❌ 提交已取消"
                exit 1
            fi
            ;;

        3)
            echo ""
            echo "❌ 提交已取消"
            echo "💡 建议：手动修改敏感信息后再提交"
            exit 1
            ;;

        *)
            echo ""
            echo "❌ 无效选项，提交已取消"
            exit 1
            ;;
    esac
else
    echo "✅ 未发现敏感信息"
fi

# 清理临时文件
rm -f "$TEMP_FILE"

exit 0
